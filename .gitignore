# Real-value copies of the placeholder/template files tracked in this
# repo (IPs, domains, WiFi creds, tokens) — never pushed to GitHub. Every
# tracked file with a placeholder (192.168.xx.xx, homebox.url,
# homeassistant.url, your-wifi-ssid, etc.) has a sibling with .local.
# inserted before its final extension, e.g. rest_commands.yaml ->
# rest_commands.local.yaml, apply-bus-config.sh -> apply-bus-config.local.sh.
*.local.*
*.local

# Homebox API token file referenced by push_display_image.sh — lives on
# the HA host at /config/homebox_auth_header.txt in practice, but keep a
# local copy out of git too if one's ever created here for convenience.
homebox_auth_header.txt

# ESP32 WiFi credentials — must keep this exact filename since
# homebox_display.ino #includes it directly (can't use the .local.
# convention above). See wifi_credentials.h.example for the tracked
# template.
wifi_credentials.h

# PlatformIO's build cache/downloaded toolchains and libraries
# (homebox_display/) — regenerated by `pio run`, not source, and huge
# (100+ MB: compiled objects plus the full lvgl/ArduinoJson/etc. library
# trees PlatformIO's package manager fetches on first build).
.pio/
